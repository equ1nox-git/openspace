#!/usr/bin/env python3
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import subprocess
import sys
import time

app = FastAPI()

MODELS = ["tiny", "coder", "reason", "voice"]

PREFIX_MAP = {
    "phi3:mini": "/tiny",
    "tiny": "/tiny",
    "mistral:7b": "/reason",
    "reason": "/reason",
    "qwen2.5-coder:7b": "/coder",
    "deepseek-coder:6.7b": "/coder",
    "deepseek-coder-v2:16b": "/coder",
    "deepseek-coder-v2:7b": "/coder",
    "coder": "/coder",
    "llama3.2:latest": "/voice",
    "voice": "/voice",
    "gemma2:9b": "/reason",
}


def run_router(model: str, prompt: str) -> str:
    prefix = PREFIX_MAP.get(model, "/tiny")
    stdin_input = f"{prefix} {prompt}\n/exit\n"
    result = subprocess.run(
        [sys.executable, "/home/thomasb/openspace/router.py"],
        input=stdin_input,
        capture_output=True,
        text=True,
        timeout=60,
        cwd="/home/thomasb/openspace",
    )
    if result.returncode != 0:
        raise HTTPException(status_code=500, detail=f"Router error: {result.stderr}")
    lines = []
    for line in result.stdout.splitlines():
        if line.startswith("> "):
            content = line[2:].strip()
            if content and not content.startswith("["):
                lines.append(content)
        elif not line.startswith("["):
            lines.append(line)
    return "\n".join(lines).strip()


# OpenAI-compatible endpoints

class ChatRequest(BaseModel):
    model: str = "tiny"
    messages: list
    stream: bool = False


@app.get("/v1/models")
async def list_models_openai():
    return {"object": "list", "data": [{"id": m, "object": "model"} for m in MODELS]}


@app.post("/v1/chat/completions")
async def chat_completions(request: ChatRequest):
    if not request.messages:
        raise HTTPException(status_code=400, detail="No messages")
    user_content = request.messages[-1].get("content", "")
    try:
        answer = run_router(request.model, user_content)
    except subprocess.TimeoutExpired:
        raise HTTPException(status_code=504, detail="Router timed out")
    return {
        "id": "chatcmpl-openspace",
        "object": "chat.completion",
        "model": request.model,
        "choices": [{"index": 0, "message": {"role": "assistant", "content": answer}, "finish_reason": "stop"}],
    }


# Ollama-compatible endpoints (Open WebUI uses these for Ollama connections)

@app.get("/api/tags")
async def ollama_tags():
    now = int(time.time())
    return {
        "models": [
            {"name": m, "model": m, "modified_at": "2026-01-01T00:00:00Z", "size": 0, "digest": m}
            for m in MODELS
        ]
    }


class OllamaGenerateRequest(BaseModel):
    model: str = "tiny"
    prompt: str = ""
    stream: bool = False


@app.post("/api/generate")
async def ollama_generate(request: OllamaGenerateRequest):
    try:
        answer = run_router(request.model, request.prompt)
    except subprocess.TimeoutExpired:
        raise HTTPException(status_code=504, detail="Router timed out")
    return {"model": request.model, "response": answer, "done": True}


if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=11435)
